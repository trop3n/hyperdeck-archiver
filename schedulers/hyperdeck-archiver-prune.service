[Unit]
Description=HyperDeck Archiver - prune (delete NAS footage older than retention)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=@@USER@@
WorkingDirectory=@@INSTALL_DIR@@
ExecStart=@@VENV_PYTHON@@ @@INSTALL_DIR@@/run.py --config @@INSTALL_DIR@@/config.yaml prune
